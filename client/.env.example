# ChatConnect — Frontend environment variables
# All Vite vars must start with VITE_.  These are PUBLIC (baked into the JS
# bundle at build time) — never put secrets here. Real secrets live only in the
# backend (server/.env locally, or the Render dashboard in production).

# ── Local development ─────────────────────────────────────────────
# Leave VITE_API_URL blank to use the Vite dev proxy (recommended locally),
# and set VITE_DEMO_MODE=false to talk to the real backend + database.
VITE_API_URL=
VITE_SOCKET_URL=
VITE_DEMO_MODE=false

# ── Production (set these in the Vercel dashboard, NOT in a committed file) ──
# VITE_API_URL   = https://your-backend.onrender.com        (with or without /api — both work)
# VITE_SOCKET_URL= https://your-backend.onrender.com        (backend origin, NO /api)
# VITE_DEMO_MODE = false
# Then on the backend (Render) set CLIENT_URL = https://your-frontend.vercel.app
# so CORS allows your deployed frontend origin.

# ── WebRTC calling ────────────────────────────────────────────────
# Google STUN works on same-LAN / localhost. For calls across the internet /
# mobile networks you MUST add a TURN server (Twilio, Metered.ca, or self-hosted
# coturn) — STUN alone can't punch through strict NATs.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
