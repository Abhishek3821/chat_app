# ChatConnect — Frontend environment variables
# Copy to `.env` (or `.env.local`). All Vite vars must start with VITE_.

# Base URL of the backend API. Leave blank to use the Vite dev proxy (recommended for local dev).
VITE_API_URL=
# Socket.IO server URL. Leave blank to use same-origin (dev proxy handles it).
VITE_SOCKET_URL=

# Set to "true" to explore the UI with built-in demo data (no backend required).
# Set to "false" for real multi-user chat + WebRTC calls (needs the backend + DB).
VITE_DEMO_MODE=true

# WebRTC calling uses Google STUN by default (works on same-LAN / localhost).
# For calls across the internet / mobile networks you MUST add a TURN server
# (e.g. Twilio, Metered.ca, or self-hosted coturn). STUN alone can't punch
# through strict NATs.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
