# ─────────────────────────────────────────────────────────
#  ChatConnect — Backend environment variables (TEMPLATE)
#  Copy this file to `.env` and fill in real values.
#  Do NOT put real secrets in this template file.
# ─────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5290

# MongoDB (Atlas SRV string — include the /chatconnect database name)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/chatconnect?appName=Cluster0

# JWT / sessions
JWT_SECRET=change_this_to_a_long_random_string
JWT_COOKIE_EXPIRES_DAYS=30
# Short-lived ACCESS token TTL — a rotating refresh cookie mints new ones via
# POST /api/auth/refresh, and every request re-validates the tracked session so
# revocation (logout / "log out other devices") is immediate.
JWT_ACCESS_EXPIRES=1h
# Session lifetimes (days): absolute cap (refresh-token max age) + idle timeout.
REFRESH_TOKEN_DAYS=30
SESSION_IDLE_DAYS=14

# Email (Nodemailer) — used for OTP / verification / password reset.
# Leave blank for local dev: codes print to the server console AND are returned
# in the API response (development only) so signup is testable without SMTP.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="ChatConnect <no-reply@chatconnect.app>"

# File storage: "local" | "cloudinary"
STORAGE_DRIVER=local

# Cloudinary (only if STORAGE_DRIVER=cloudinary). Either set CLOUDINARY_URL, or
# the three split vars below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Horizontal scaling (ALL OPTIONAL) ────────────────────────────
# Set REDIS_URL to run more than one backend instance behind a load balancer.
# It turns on: the Socket.IO Redis adapter (cross-instance message/presence
# fan-out), a shared rate-limit store, response caching, and a BullMQ worker
# for notification/push fan-out. Leave blank → single-instance, in-memory,
# inline jobs (identical behaviour, no extra infra needed).
REDIS_URL=

# ── Web Push notifications (OPTIONAL) ────────────────────────────
# Generate a keypair once with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
# Leave blank → push is disabled gracefully (in-app + socket notifications still work).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@chatconnect.app

# Optional: force Node to use specific DNS servers (helps when a corporate
# network refuses MongoDB SRV lookups). Defaults to 8.8.8.8,1.1.1.1.
DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional: extra comma-separated allowed CORS origins (in addition to CLIENT_URL)
EXTRA_CORS_ORIGINS=

# Feature flags
# When true, signup sends a 6-digit OTP to verify the email before login.
# If EMAIL_* is not configured, the OTP is printed to the server console AND
# returned in the API response in development so you can still test.
ENABLE_EMAIL_VERIFICATION=true
