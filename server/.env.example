# ─────────────────────────────────────────────────────────
#  ChatConnect — Backend environment variables (TEMPLATE)
#  Copy this file to `.env` and fill in real values.
#  Do NOT put real secrets in this template file.
# ─────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5290

# MongoDB (Atlas SRV string — include the /chatconnect database name)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/chatconnect?appName=Cluster0

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=30d
JWT_COOKIE_EXPIRES_DAYS=30

# Email (Nodemailer) — used for OTP / verification / password reset.
# Leave blank for local dev: codes print to the server console AND are returned
# in the API response (development only) so signup is testable without SMTP.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="ChatConnect <no-reply@chatconnect.app>"

# File storage: "local" | "cloudinary"
STORAGE_DRIVER=local

# Cloudinary (only if STORAGE_DRIVER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: force Node to use specific DNS servers (helps when a corporate
# network refuses MongoDB SRV lookups). Defaults to 8.8.8.8,1.1.1.1.
DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional: extra comma-separated allowed CORS origins (in addition to CLIENT_URL)
EXTRA_CORS_ORIGINS=

# Feature flags
# When true, signup sends a 6-digit OTP to verify the email before login.
# If EMAIL_* is not configured, the OTP is printed to the server console AND
# returned in the API response in development so you can still test.
ENABLE_EMAIL_VERIFICATION=true
